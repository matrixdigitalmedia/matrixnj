---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="HiveHelper — Matrix Digital Media"
  description="The complete inspection logbook for hobbyist beekeepers. Log hive health, track observations, and get AI-powered guidance."
>
  <Header />

  <main class="app-page">
    <div class="container">

      <div class="app-hero">
        <a href="/#apps" class="back-link">← All Apps</a>

        <div class="app-header">
          <div class="app-icon">
            <svg width="48" height="48" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <radialGradient id="hh-bg" cx="50%" cy="45%" r="70%">
                  <stop offset="0%" stop-color="#FDF6EC"/>
                  <stop offset="100%" stop-color="#E8DDD0"/>
                </radialGradient>
                <linearGradient id="hh-amber" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#F59E0B"/>
                  <stop offset="100%" stop-color="#F97316"/>
                </linearGradient>
                <clipPath id="hh-abd"><ellipse cx="512" cy="524" rx="44" ry="60"/></clipPath>
              </defs>
              <rect width="1024" height="1024" rx="230" fill="url(#hh-bg)"/>
              <polygon points="512,64 896,277 896,747 512,960 128,747 128,277" fill="url(#hh-amber)" opacity="0.10"/>
              <polygon points="512,64 896,277 896,747 512,960 128,747 128,277" fill="none" stroke="url(#hh-amber)" stroke-width="28" stroke-linejoin="round"/>
              <polygon points="512,256 725,384 725,640 512,768 299,640 299,384" fill="url(#hh-amber)" opacity="0.28"/>
              <path d="M 510,382 C 490,326 366,304 310,384 C 264,450 292,554 410,562 C 464,566 496,532 510,506 Z" fill="#FDF6EC" stroke="#1A0D00" stroke-width="32" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M 514,382 C 534,326 658,304 714,384 C 760,450 732,554 614,562 C 560,566 528,532 514,506 Z" fill="#FDF6EC" stroke="#1A0D00" stroke-width="32" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M 364,452 Q 396,416 428,452" fill="none" stroke="#1A0D00" stroke-width="18" stroke-linecap="round"/>
              <path d="M 596,452 Q 628,416 660,452" fill="none" stroke="#1A0D00" stroke-width="18" stroke-linecap="round"/>
              <ellipse cx="512" cy="524" rx="44" ry="60" fill="#1A0D00"/>
              <rect x="468" y="490" width="88" height="14" fill="#F59E0B" clip-path="url(#hh-abd)"/>
              <rect x="468" y="516" width="88" height="14" fill="#F59E0B" clip-path="url(#hh-abd)"/>
              <rect x="468" y="542" width="88" height="14" fill="#F59E0B" clip-path="url(#hh-abd)"/>
              <circle cx="512" cy="418" r="48" fill="#1A0D00"/>
              <circle cx="512" cy="328" r="28" fill="#1A0D00"/>
              <path d="M 498,302 Q 466,260 446,236" fill="none" stroke="#1A0D00" stroke-width="10" stroke-linecap="round"/>
              <circle cx="446" cy="236" r="11" fill="#1A0D00"/>
              <path d="M 526,302 Q 558,260 578,236" fill="none" stroke="#1A0D00" stroke-width="10" stroke-linecap="round"/>
              <circle cx="578" cy="236" r="11" fill="#1A0D00"/>
              <path d="M 380,632 C 430,695 594,695 644,632" fill="none" stroke="#1A0D00" stroke-width="22" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <div class="app-title-row">
              <h1 class="app-title">HiveHelper</h1>
              <span class="app-badge">iOS</span>
            </div>
            <p class="app-category">Lifestyle · Beekeeping</p>
          </div>
        </div>

        <p class="app-tagline">
          The complete inspection logbook for hobbyist beekeepers.
        </p>

        <div class="app-actions">
          <span class="btn-store btn-store--soon">Coming to the App Store</span>
        </div>
      </div>

      <div class="features-grid">
        <div class="feature">
          <h3>Hive Inspections</h3>
          <p>Log every inspection with structured checklists — queen status, brood patterns, honey stores, and more.</p>
        </div>
        <div class="feature">
          <h3>AI Guidance</h3>
          <p>Get context-aware recommendations after each inspection, powered by GPT-4o mini.</p>
        </div>
        <div class="feature">
          <h3>Photo Logs</h3>
          <p>Attach photos to any inspection and build a visual history of each hive over time.</p>
        </div>
        <div class="feature">
          <h3>Offline First</h3>
          <p>Works entirely without a connection. Your data stays on your device, always available.</p>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .app-page {
    padding-top: calc(var(--header-h) + 4rem);
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-head);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--text); }

  .app-hero {
    max-width: 680px;
    margin-bottom: 5rem;
  }

  .app-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .app-icon {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .app-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.2rem;
  }

  .app-title {
    font-family: var(--font-head);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .app-badge {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-3);
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.25);
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
  }

  .app-category {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .app-tagline {
    font-size: 1.2rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .btn-store--soon {
    display: inline-block;
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1.5rem;
  }

  .feature {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .feature h3 {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }

  .feature p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .app-page {
      padding-top: calc(var(--header-h) + 2rem);
      padding-bottom: 2rem;
    }

    .app-hero {
      margin-bottom: 3rem;
    }

    .app-title {
      font-size: 1.6rem;
    }
  }
</style>
