---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Matrix Digital Media — We build apps people actually use."
  description="Matrix Digital Media LLC is a digital product studio creating focused, purposeful software for everyday life."
>
  <Header />

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="grid-overlay"></div>
      </div>
      <div class="container hero-content">
        <p class="hero-eyebrow">Matrix Digital Media</p>
        <h1 class="hero-headline">
          We build apps<br />
          <span class="gradient-text">people actually use.</span>
        </h1>
        <p class="hero-sub">
          A digital product studio creating focused, purposeful software
          for everyday life. No bloat. No noise. Just tools that work.
        </p>
        <a href="#apps" class="btn-primary">Explore Our Apps</a>
      </div>
    </section>

    <!-- APPS -->
    <section class="section" id="apps">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Our Apps</h2>
          <p class="section-sub">Software built around real-world needs.</p>
        </div>
        <div class="apps-grid">
          <a href="/apps/hivehelper" class="app-card">
            <div class="app-icon">
              <svg width="40" height="40" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <radialGradient id="hm-bg" cx="50%" cy="45%" r="70%">
                    <stop offset="0%" stop-color="#FDF6EC"/>
                    <stop offset="100%" stop-color="#E8DDD0"/>
                  </radialGradient>
                  <linearGradient id="hm-amber" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#F59E0B"/>
                    <stop offset="100%" stop-color="#F97316"/>
                  </linearGradient>
                  <clipPath id="hm-abd">
                    <ellipse cx="512" cy="510" rx="50" ry="66"/>
                  </clipPath>
                </defs>
                <rect width="1024" height="1024" rx="230" fill="url(#hm-bg)"/>
                <polygon points="512,64 896,277 896,747 512,960 128,747 128,277" fill="url(#hm-amber)" opacity="0.10"/>
                <polygon points="512,64 896,277 896,747 512,960 128,747 128,277" fill="none" stroke="url(#hm-amber)" stroke-width="28" stroke-linejoin="round"/>
                <polygon points="512,256 725,384 725,640 512,768 299,640 299,384" fill="url(#hm-amber)" opacity="0.28"/>
                <path d="M 510,350 C 494,298 406,278 370,346 C 342,402 362,490 440,500 C 474,503 496,476 510,454" fill="none" stroke="#1A0D00" stroke-width="26" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M 514,350 C 530,298 618,278 654,346 C 682,402 662,490 584,500 C 550,503 528,476 514,454" fill="none" stroke="#1A0D00" stroke-width="26" stroke-linecap="round" stroke-linejoin="round"/>
                <ellipse cx="512" cy="510" rx="50" ry="66" fill="#1A0D00"/>
                <rect x="462" y="488" width="100" height="34" fill="#F59E0B" clip-path="url(#hm-abd)"/>
                <circle cx="512" cy="400" r="52" fill="#1A0D00"/>
                <circle cx="512" cy="306" r="30" fill="#1A0D00"/>
                <path d="M 498,282 Q 468,244 448,220" fill="none" stroke="#1A0D00" stroke-width="10" stroke-linecap="round"/>
                <circle cx="448" cy="220" r="12" fill="#1A0D00"/>
                <path d="M 526,282 Q 556,244 576,220" fill="none" stroke="#1A0D00" stroke-width="10" stroke-linecap="round"/>
                <circle cx="576" cy="220" r="12" fill="#1A0D00"/>
              </svg>
            </div>
            <div class="app-info">
              <div class="app-meta">
                <span class="app-name">HiveHelper</span>
                <span class="app-badge">iOS</span>
              </div>
              <p class="app-category">Lifestyle · Beekeeping</p>
              <p class="app-desc">
                The complete inspection logbook for hobbyist beekeepers.
                Log hive health, track observations, and get AI-powered guidance.
              </p>
            </div>
            <span class="app-arrow">→</span>
          </a>

          <!-- Placeholder for next app -->
          <div class="app-card app-card--coming">
            <div class="app-icon app-icon--dim">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect x="8" y="8" width="24" height="24" rx="6" stroke="#3a3a5c" stroke-width="1.5" stroke-dasharray="4 3"/>
              </svg>
            </div>
            <div class="app-info">
              <span class="app-name" style="color: var(--text-muted);">Next App</span>
              <p class="app-desc" style="color: var(--text-muted);">Something new is in the works.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MISSION -->
    <section class="section section--dark">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">How We Build</h2>
          <p class="section-sub">Three principles behind every product we ship.</p>
        </div>
        <div class="pillars-grid">
          <div class="pillar">
            <div class="pillar-number">01</div>
            <h3 class="pillar-title">Focused</h3>
            <p class="pillar-desc">
              Every app does one thing and does it well. We don't chase features —
              we find the core problem and solve it completely.
            </p>
          </div>
          <div class="pillar">
            <div class="pillar-number">02</div>
            <h3 class="pillar-title">Purposeful</h3>
            <p class="pillar-desc">
              Every screen, every interaction earns its place. If it doesn't serve
              the user directly, it doesn't ship.
            </p>
          </div>
          <div class="pillar">
            <div class="pillar-number">03</div>
            <h3 class="pillar-title">Crafted</h3>
            <p class="pillar-desc">
              The details others skip are the ones we obsess over. Good software
              feels effortless because someone cared about the hard parts.
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ---- HERO ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: #6366f1;
    top: -100px;
    left: -100px;
  }

  .orb-2 {
    width: 500px;
    height: 500px;
    background: #a855f7;
    bottom: -80px;
    right: -80px;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: var(--header-h);
    padding-bottom: 4rem;
  }

  .hero-eyebrow {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-1);
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    font-family: var(--font-head);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }

  .gradient-text {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 520px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .btn-primary {
    display: inline-block;
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: var(--gradient);
    padding: 0.8rem 2rem;
    border-radius: 8px;
    letter-spacing: 0.02em;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  /* ---- SHARED SECTION ---- */
  .section {
    padding: 7rem 0;
  }

  .section--dark {
    background: linear-gradient(180deg, transparent 0%, rgba(99, 102, 241, 0.04) 50%, transparent 100%);
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--text-muted);
  }

  /* ---- APPS GRID ---- */
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
    gap: 1.5rem;
  }

  .app-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    position: relative;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    cursor: pointer;
  }

  .app-card:not(.app-card--coming):hover {
    background: var(--bg-card-hover);
    border-color: rgba(99, 102, 241, 0.4);
    transform: translateY(-2px);
  }

  .app-card--coming {
    opacity: 0.5;
    cursor: default;
  }

  .app-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .app-info {
    flex: 1;
    min-width: 0;
  }

  .app-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.15rem;
  }

  .app-name {
    font-family: var(--font-head);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
  }

  .app-badge {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-3);
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.25);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .app-category {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .app-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .app-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    align-self: center;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }

  .app-card:not(.app-card--coming):hover .app-arrow {
    color: var(--accent-1);
    transform: translateX(3px);
  }

  /* ---- PILLARS ---- */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .pillar {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem;
  }

  .pillar-number {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  .pillar-title {
    font-family: var(--font-head);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .pillar-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .hero-sub {
      font-size: 1rem;
    }

    .section {
      padding: 4rem 0;
    }

    .section-header {
      margin-bottom: 2rem;
    }

    .pillars-grid {
      grid-template-columns: 1fr;
    }

    .app-card {
      padding: 1.25rem;
    }
  }
</style>
